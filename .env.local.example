# Supabase — safe to expose client-side
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER ONLY, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=

# GitHub Actions secrets (set separately in repo Settings -> Secrets):
# SUPABASE_URL = same value as NEXT_PUBLIC_SUPABASE_URL above
# SUPABASE_SERVICE_ROLE_KEY = same as above

# Geoapify - SERVER ONLY
GEOAPIFY_API_KEY=

# GitHub Actions workflow dispatch — SERVER ONLY
GITHUB_REPO_NAME=
GITHUB_REPO_OWNER=
GITHUB_TOKEN=

# Seed trigger API shared secret — SERVER ONLY (generate using `openssl rand -hex 32`)
SEED_TRIGGER_SECRET=
